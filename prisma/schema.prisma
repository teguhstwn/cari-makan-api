// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Tabel untuk menyimpan tempat makan yang disimpan
model Merchant {
  id              Int      @id @default(autoincrement())
  google_place_id String   @unique @db.VarChar(100)
  nama_merchant   String   @db.VarChar(150)
  alamat          String?  @db.Text
  createdAt       DateTime @default(now())

  @@map("merchants")
}
