// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Tabel untuk menyimpan tempat makan yang disimpan
model Merchant {
  id              Int        @id @default(autoincrement())
  google_place_id String     @unique @db.VarChar(100)
  nama_merchant   String     @db.VarChar(150)
  alamat          String?    @db.Text
  createdAt       DateTime   @default(now())
  favorites       Favorite[]

  @@map("merchants")
}

model User {
  id           String     @id @default(uuid()) @db.VarChar(100)
  username     String     @unique @db.VarChar(50)
  email        String     @unique @db.VarChar(100)
  password     String     @db.VarChar(255)
  nama_lengkap String?    @db.VarChar(150)
  createdAt    DateTime   @default(now())
  favorites    Favorite[]

  @@map("users")
}

model Favorite {
  id          Int      @id @default(autoincrement())
  user_id     String   @db.VarChar(100)
  merchant_id Int
  createdAt   DateTime @default(now())

  // Relations
  merchant Merchant @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("favorites")
}
